# API 配置示例
# 复制此文件为 .env 并填入你的 API Key

# 智谱 AI
ANTHROPIC_BASE_URL=https://open.bigmodel.cn
MODEL_ID=glm-4
ANTHROPIC_API_KEY=your_api_key_here

